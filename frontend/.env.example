# Frontend Environment Variables
# Copy this file to .env and update values

# API URL for production (Railway/Render backend URL)
# Leave EMPTY for development (uses Vite proxy to localhost:8081)
# For production: https://your-backend.railway.app
VITE_API_URL=

# Google OAuth Client ID (from Google Cloud Console)
# 1. Go to https://console.cloud.google.com/
# 2. Create or select a project
# 3. Go to APIs & Services > Credentials > Create Credentials > OAuth Client ID
# 4. Choose "Web application"
# 5. Add authorized JavaScript origins: http://localhost:8000 (dev) and your production URL
# 6. Copy the Client ID here
VITE_GOOGLE_CLIENT_ID=779771785213-k91mak9e3c5u9l5lqq264r59slv3q46m.apps.googleusercontent.com
