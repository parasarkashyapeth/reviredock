# ===========================================
# BACKEND ENVIRONMENT VARIABLES
# ===========================================
# Copy this file to .env and update values

# JWT Secret (Generate a strong random string for production!)
JWT_SECRET=your-super-secret-jwt-key-change-this

# Server Port
PORT=8080

# Supabase Configuration (Get from Supabase Dashboard > Settings > API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# Frontend URL (CRITICAL for QR code generation)
# This is the URL where your frontend is deployed
# DEVELOPMENT: http://localhost:8000
# PRODUCTION: https://your-app.vercel.app
FRONTEND_URL=https://your-app.vercel.app

# SMTP (for Nodemailer, required for OTP/email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@email.com
SMTP_PASS=yourpassword
SMTP_FROM="Feedback System" <noreply@feedback.app>

# No Resend support. Only SMTP is used for all emails.

# Razorpay Payment Gateway (https://dashboard.razorpay.com/app/keys)
# 1. Sign up at https://razorpay.com
# 2. Go to Settings > API Keys > Generate Key
# 3. Use "Test" keys for development, "Live" keys for production
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Razorpay Webhook Secret
# Create webhook at: Razorpay Dashboard > Settings > Webhooks
# URL: https://your-backend-url/api/payment/webhook
# Events: payment_link.paid, payment.failed
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret
